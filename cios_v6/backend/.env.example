# ─────────────────────────────────────────────────────────
#  CIOS Environment — copy this file to .env
# ─────────────────────────────────────────────────────────

# App
ENVIRONMENT=development
DEBUG=true

# ── Database ─────────────────────────────────────────────
# SQLite (default — works with no extra install)
DATABASE_URL=sqlite+aiosqlite:///./cios_dev.db

# PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql://cios_user:cios_secret@localhost:5432/cios_db

# ── Redis (optional — only needed for production event bus) ──
# Leave blank to use in-memory event bus (fine for development)
REDIS_URL=

# ── JWT ──────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── AI (optional) ────────────────────────────────────────
# Add your key to enable LLM-powered clinical summaries
# Works without it — falls back to rule-based summaries
ANTHROPIC_API_KEY=

# ── Reports ──────────────────────────────────────────────
REPORTS_DIR=./reports
